# Local demo defaults. Copy to .env and adjust.
PORT=4000
NODE_ENV=development

# SQLite file for local demo. In production this becomes Azure Postgres.
DATABASE_URL=apps/server/data/loancom.db

# Local attachment storage. In production this becomes Azure Blob.
ATTACHMENT_DIR=apps/server/storage

# Inbound integration API key (loan-origination app). Demo value; rotate in prod.
INBOUND_API_KEY=demo-inbound-key

# Production-only (M4): Entra OIDC + Microsoft Graph + Azure Blob.
# ENTRA_TENANT_ID=
# ENTRA_API_CLIENT_ID=
# ENTRA_API_AUDIENCE=api://loancom
# ENTRA_GROUP_OWNER=
# ENTRA_GROUP_OFFICER=
# AZURE_BLOB_CONNECTION=
# AZURE_BLOB_CONTAINER=loancom-attachments
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_SHARED_MAILBOX=committee@example.com
# GRAPH_SUBSCRIPTION_NOTIFICATION_URL=https://loancom.example.com/api/graph/notifications
# GRAPH_SUBSCRIPTION_CLIENT_STATE=
